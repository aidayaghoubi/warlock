{
  "compilerOptions": {
    "target": "ES2022",
    // DOM is here only so the type-only Canvas references in maps.ts resolve; the
    // server never touches the DOM at runtime (esbuild strips types).
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,

    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    "strict": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["server"]
}
